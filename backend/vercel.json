{
    "version": 2,
    "builds": [
        {
            "src": "index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/socket.io/(.*)",
            "dest": "index.js"
        },
        {
            "src": "/(.*)",
            "headers": {
                "Access-Control-Allow-Origin": "https://smart-sps.vercel.app",
                "Access-Control-Allow-Methods": "GET,POST,PUT,DELETE,OPTIONS",
                "Access-Control-Allow-Headers": "Content-Type, Authorization, X-Requested-With, Accept, X-Clerk-Auth-Token",
                "Access-Control-Allow-Credentials": "true"
            },
            "dest": "index.js"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    }
}